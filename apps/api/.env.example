# NestJS API Configuration
PORT=3001

# Authentication
API_KEY=my-secret-api-key

# Database (shared with packages/database)
DATABASE_URL=postgresql://user:password@localhost:5432/ticketing
DATABASE_POOL_SIZE=10

# Redis (optional — app works without it, just no caching)
REDIS_URL=redis://localhost:6379

# Pricing Engine Weights (default: 1.0)
PRICING_TIME_WEIGHT=1.0
PRICING_DEMAND_WEIGHT=1.0
PRICING_INVENTORY_WEIGHT=1.0
